{
  "name": "tickerhub-cli",
  "version": "0.1.0",
  "description": "CLI wrapper around tickerhub with SQLite caching for agent market data access",
  "license": "MIT",
  "author": "Hicham Kazan",
  "type": "module",
  "bin": {
    "tickerhub": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "tickerhub": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
